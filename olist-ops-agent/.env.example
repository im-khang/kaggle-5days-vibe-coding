# Olist Ecommerce Analytics Agent — environment template
# Copy to .env and fill in your values.

# GCP project — your own project with BigQuery enabled
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
BQ_DATASET_ID=olist_ecommerce
BQ_DATASET_LOCATION=US

# Vertex AI
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_LOCATION=us-central1

# Cost / safety caps (enforced inside olist_ops/tools.py)
# - SELECT-only validation; INSERT/UPDATE/DELETE/DDL/MERGE rejected.
# - maximum_bytes_billed = 10 GiB per query.
# - 30s query timeout.
# - Result rows truncated to 1000.
