# Olist Ecommerce Analytics Agent — environment template
# Copy to .env and fill in your values.
# Public/default path: use Vertex AI or Google AI Studio API key.

# GCP project — your own project with BigQuery enabled
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
BQ_DATASET_ID=olist_ecommerce
BQ_DATASET_LOCATION=US

# Option A (recommended): Vertex AI + Application Default Credentials
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_LOCATION=us-central1
OLIST_MODEL_PROVIDER=vertex
OLIST_MODEL=gemini-2.5-flash

# Option B: Google AI Studio API key
# GOOGLE_GENAI_USE_VERTEXAI=0
# GOOGLE_API_KEY=your-gemini-api-key
# OLIST_MODEL_PROVIDER=vertex
# OLIST_MODEL=gemini-2.5-flash

# Cost / safety caps (enforced inside olist_ops/tools.py)
# - SELECT-only validation; INSERT/UPDATE/DELETE/DDL/MERGE rejected.
# - maximum_bytes_billed = 10 GiB per query.
# - 30s query timeout.
# - Result rows truncated to 1000.
